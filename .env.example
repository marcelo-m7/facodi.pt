# FACODI Environment Configuration Example
# This file shows required environment variables.
# For local development, see .env (committed to repo with public keys only).
# For sensitive overrides, create .env.local (ignored by git).

# Supabase Configuration (public keys only - safe to commit)
SITE_URL=https://facodi.com
VITE_SITE_URL=https://facodi.com
VITE_SUPABASE_URL=https://wvkjainfwsyiyfcmbtid.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_nM6B639oi-4lNLB-H3BEUw_3SgNQ_Ky

# Feature Flags
VITE_ENABLE_RECOMMENDATIONS=true
VITE_ENABLE_RATINGS=true
VITE_ENABLE_SOCIAL_FEATURES=true
VITE_ENABLE_PWA=true

# Data Source (optional, defaults to 'mock')
# Valid options: 'mock' (fallback), 'supabase' (live data)
# VITE_DATA_SOURCE=supabase

# ===== SECURITY NOTES =====
# 1. VITE_SUPABASE_PUBLISHABLE_KEY is PUBLIC (safe in version control)
#    It's restricted to anon/authenticated roles only.
#
# 2. NEVER commit service_role_key or secret keys.
#    Keep these on server-side only.
#
# 3. Local overrides: Create .env.local for your environment.
#    Example: VITE_SUPABASE_URL=[your-staging-project-url]
#
# Learn more: See CONTRIBUTING.md and SUPABASE_AUDIT_REPORT.md