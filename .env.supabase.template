# Environment Variables Template - Supabase Configuration

# Copy this to .env.local and fill in your Supabase credentials

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Supabase Project URL (from Supabase Dashboard → Settings → API)
# Format: https://your-project-id.supabase.co
SUPABASE_URL=https://your-project.supabase.co

# Supabase Service Role Key (NEVER expose to frontend)
# Format: sbp_... (long string)
# IMPORTANT: Keep this secret! Use this for server-side operations only.
# Find in: Supabase Dashboard → Settings → API → Service Role Key
SUPABASE_SERVICE_ROLE_KEY=sbp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Anon Key (safe to expose to frontend)
# Format: eyJ0eXAi... (JWT-like string)
# Find in: Supabase Dashboard → Settings → API → Anon public
SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# ============================================================================
# FRONTEND ENVIRONMENT (Safe to expose - remove SUPABASE_SERVICE_ROLE_KEY)
# These should be in frontend/.env.local
# ============================================================================

VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ0eXAiOiJKV1QiLCJhbGciOiJIUzI1NiJ9...

# ============================================================================
# OTHER CONFIGURATION
# ============================================================================

# Backend API Port
BACKEND_API_PORT=8000

# Frontend Development Port
FRONTEND_DEV_PORT=3000

# Environment
NODE_ENV=development
# Values: development, staging, production

# ============================================================================
# NOTES
# ============================================================================

# 1. Never commit .env.local to git (it's in .gitignore)
# 2. Service Role Key is SECRET - only use in backend
# 3. Anon Key is public - safe in frontend
# 4. Always use latest credentials after rotating keys
# 5. For production, use environment variables from hosting platform
#    (Vercel, Railway, Heroku, etc.) instead of .env files

# ============================================================================
# HOW TO GET CREDENTIALS
# ============================================================================

# 1. Go to https://supabase.com and log in
# 2. Select FACODI project
# 3. Click "Settings" (gear icon, bottom left)
# 4. Click "API" in the left menu
# 5. Copy values:
#    - Project URL: Top of page
#    - Service Role Key: Under "Service Role"
#    - Anon public: Under "Anon"
